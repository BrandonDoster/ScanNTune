<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ScanNTune.Browser.App"
             xmlns:ui="using:ScanNTune.UI"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <ui:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://ScanNTune.UI/Themes/Colors.Graphite.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://ScanNTune.UI/Themes/Skins/Skin.Classic.axaml"/>
    </Application.Styles>
</Application>
