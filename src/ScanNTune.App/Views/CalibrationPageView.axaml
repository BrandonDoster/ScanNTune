<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScanNTune.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="820"
             x:Class="ScanNTune.App.Views.CalibrationPageView"
             x:DataType="vm:CalibrationPageViewModel">

    <UserControl.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style Selector="Border.tile">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style Selector="TextBlock.h4">
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TextBlock.tip">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style Selector="TextBlock.tlab">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.tval">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Consolas,monospace"/>
        </Style>
        <Style Selector="TextBlock.sanity">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.sanity.warn">
            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
        </Style>
    </UserControl.Styles>

    <DockPanel>

        <!-- Top bar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}" Padding="14,10"
                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Content="←  Scan" Command="{Binding BackCommand}" Padding="9,5" FontSize="13"/>
                <TextBlock Text="Scanner calibration" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="one-time" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="PageDrop" DragDrop.AllowDrop="True" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20" Spacing="14" MaxWidth="820" HorizontalAlignment="Center">

                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="Scan a bank card once, enter its measured long side and your scan DPI, and the tool auto-detects the card edges to read your scanner's true pixels-per-mm. It's stored and reused for every scan afterwards."/>

                <!-- 1 · How to scan -->
                <Border Classes="panel">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <TextBlock Text="1" Foreground="{DynamicResource PrimaryBrush}" Classes="h4"/>
                            <TextBlock Text="How to scan" Classes="h4"/>
                        </StackPanel>
                        <Viewbox Stretch="Uniform" HorizontalAlignment="Center" Height="200">
                            <Canvas Width="420" Height="200">
                                <Line StartPoint="172,18" EndPoint="300,18" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="2"/>
                                <Polyline Points="291,13 300,18 291,23" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.8"/>
                                <TextBlock Canvas.Left="66" Canvas.Top="10" Text="scan direction" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>

                                <Rectangle Canvas.Left="56" Canvas.Top="28" Width="250" Height="164" RadiusX="12" RadiusY="12"
                                           Fill="{DynamicResource SurfaceBrush}" Stroke="{DynamicResource BorderStrongBrush}" StrokeThickness="1"/>
                                <Rectangle Canvas.Left="56" Canvas.Top="28" Width="250" Height="12" RadiusX="6" RadiusY="6"
                                           Fill="{DynamicResource BackgroundBrush}" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                                <Ellipse Canvas.Left="94" Canvas.Top="32" Width="4" Height="4" Fill="{DynamicResource TextSecondaryBrush}"/>
                                <Ellipse Canvas.Left="264" Canvas.Top="32" Width="4" Height="4" Fill="{DynamicResource TextSecondaryBrush}"/>

                                <Rectangle Canvas.Left="72" Canvas.Top="46" Width="210" Height="140" RadiusX="6" RadiusY="6"
                                           Fill="{DynamicResource BackgroundBrush}" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                                <Rectangle Canvas.Left="84" Canvas.Top="58" Width="186" Height="116" RadiusX="4" RadiusY="4"
                                           Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1" StrokeDashArray="4,3"/>

                                <Rectangle Canvas.Left="120" Canvas.Top="46" Width="6" Height="140" RadiusX="2" RadiusY="2" Fill="{DynamicResource PrimaryBrush}"/>
                                <Polyline Points="132,110 139,117 132,124" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="1.5"/>
                                <Polyline Points="144,110 151,117 144,124" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="1.5"/>

                                <Rectangle Canvas.Left="162" Canvas.Top="82" Width="48" Height="76" RadiusX="7" RadiusY="7" Fill="#2F80D8"/>
                                <Rectangle Canvas.Left="168" Canvas.Top="90" Width="11" Height="8" RadiusX="2" RadiusY="2" Fill="#BCD8F2"/>
                                <Line StartPoint="162,82" EndPoint="210,82" Stroke="{DynamicResource SuccessBrush}" StrokeThickness="4"/>
                                <Line StartPoint="162,158" EndPoint="210,158" Stroke="{DynamicResource SuccessBrush}" StrokeThickness="4"/>
                                <Line StartPoint="162,82" EndPoint="162,158" Stroke="{DynamicResource WarningBrush}" StrokeThickness="2.2"/>
                                <Line StartPoint="210,82" EndPoint="210,158" Stroke="{DynamicResource WarningBrush}" StrokeThickness="2.2"/>

                                <Rectangle Canvas.Left="316" Canvas.Top="92" Width="14" Height="4" RadiusX="2" Fill="{DynamicResource SuccessBrush}"/>
                                <TextBlock Canvas.Left="336" Canvas.Top="86" Text="measure · clean" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <Rectangle Canvas.Left="316" Canvas.Top="118" Width="14" Height="4" RadiusX="2" Fill="{DynamicResource WarningBrush}"/>
                                <TextBlock Canvas.Left="336" Canvas.Top="112" Text="may shadow" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Classes="tip" Text="• The two edges you measure (green) run with the sweep, so they stay shadow-free."/>
                        <TextBlock Classes="tip" Text="• Lay the card fully on the glass, off every border."/>
                    </StackPanel>
                </Border>

                <!-- 2 · What to measure  +  3 · Your numbers -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">

                    <Border Grid.Column="0" Classes="panel">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <TextBlock Text="2" Foreground="{DynamicResource PrimaryBrush}" Classes="h4"/>
                                <TextBlock Text="What to measure" Classes="h4"/>
                            </StackPanel>
                            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" Height="170">
                                <Canvas Width="300" Height="170">
                                    <Rectangle Canvas.Left="52" Canvas.Top="22" Width="158" Height="100" RadiusX="10" RadiusY="10" Fill="#2F80D8"/>
                                    <Rectangle Canvas.Left="62" Canvas.Top="31" Width="20" Height="14" RadiusX="3" RadiusY="3" Fill="#BCD8F2"/>
                                    <Ellipse Canvas.Left="176" Canvas.Top="97" Width="18" Height="18" Fill="#E0563F"/>
                                    <Ellipse Canvas.Left="188" Canvas.Top="97" Width="18" Height="18" Fill="#EAA63F"/>

                                    <Line StartPoint="52,122" EndPoint="52,150" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                                    <Line StartPoint="210,122" EndPoint="210,150" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                                    <Line StartPoint="52,146" EndPoint="210,146" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="1.6"/>
                                    <Polyline Points="60,141 52,146 60,151" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="1.5"/>
                                    <Polyline Points="202,141 210,146 202,151" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="1.5"/>
                                    <Rectangle Canvas.Left="103" Canvas.Top="136" Width="56" Height="20" RadiusX="6" RadiusY="6" Fill="{DynamicResource SurfaceAltBrush}"/>
                                    <TextBlock Canvas.Left="111" Canvas.Top="138" Text="85.6 mm" FontSize="12" Foreground="{DynamicResource PrimaryBrush}"/>

                                    <Line StartPoint="210,22" EndPoint="242,22" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                                    <Line StartPoint="210,122" EndPoint="242,122" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                                    <Line StartPoint="236,22" EndPoint="236,122" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.4"/>
                                    <Polyline Points="231,30 236,22 241,30" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.3"/>
                                    <Polyline Points="231,114 236,122 241,114" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.3"/>
                                    <TextBlock Canvas.Left="246" Canvas.Top="64" Text="54 mm" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Classes="tip" Text="• Measure the long side — mid-edge, avoiding the rounded corners."/>
                            <TextBlock Classes="tip" Text="• To 0.01 mm; checked against the 85.60 mm ISO nominal."/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="panel">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <TextBlock Text="3" Foreground="{DynamicResource PrimaryBrush}" Classes="h4"/>
                                <TextBlock Text="Your numbers" Classes="h4"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Measured long side" Classes="tlab"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBox Text="{Binding MeasuredMmText}" Width="110" PlaceholderText="85.50"/>
                                    <TextBlock Text="mm" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Scan resolution" Classes="tlab"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBox Text="{Binding DpiText}" Width="110" PlaceholderText="600"/>
                                    <TextBlock Text="dpi" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="{Binding IsoSanityText}" TextWrapping="Wrap" FontSize="12"
                                       Classes="sanity" Classes.warn="{Binding IsoSanityWarn}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Upload (the whole page is also a drop target) -->
                <Border BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1.4" CornerRadius="12"
                        Padding="22" IsVisible="{Binding !HasResult}">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Text="Drop your card scan here, or upload" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Text="PNG, JPG or TIFF — most card colours; a pale card needs a dark sheet behind it"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="360"/>
                        <Button Content="Choose file" Classes="accent" HorizontalAlignment="Center"
                                Padding="14,8" Click="OnUpload" IsEnabled="{Binding CanUpload}"/>
                        <TextBlock Text="Enter your measurement and DPI first" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                   IsVisible="{Binding !CanUpload}"/>
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsDetecting}" Height="4" Width="220"/>
                    </StackPanel>
                </Border>

                <!-- Result -->
                <Border Classes="panel" IsVisible="{Binding HasResult}">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="✓" Foreground="{DynamicResource SuccessBrush}" FontSize="16"/>
                            <TextBlock Text="Card detected" FontWeight="Medium"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                            <Border Grid.Column="0" Classes="tile">
                                <StackPanel Spacing="3">
                                    <TextBlock Classes="tlab" Text="px / mm"/>
                                    <TextBlock Classes="tval" Text="{Binding PxPerMmText}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="tile">
                                <StackPanel Spacing="3">
                                    <TextBlock Classes="tlab" Text="effective dpi"/>
                                    <TextBlock Classes="tval" Text="{Binding EffectiveDpiText}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Classes="tile">
                                <StackPanel Spacing="3">
                                    <TextBlock Classes="tlab" Text="vs nominal"/>
                                    <TextBlock Classes="tval" Text="{Binding PercentText}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding EdgeQualityText}" FontSize="12.5" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding SizeSentence}" FontSize="12.5" TextWrapping="Wrap"
                                       Classes="sanity" Classes.warn="{Binding !SizeCheckOk}"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                <TextBlock Text="✓" Foreground="{DynamicResource SuccessBrush}" IsVisible="{Binding Saved}"/>
                                <TextBlock Text="Saved — used for every scan" FontSize="12.5"
                                           Foreground="{DynamicResource SuccessBrush}" IsVisible="{Binding Saved}"/>
                                <TextBlock Text="Not saved — resolve the size check above" FontSize="12.5"
                                           Foreground="{DynamicResource WarningBrush}" IsVisible="{Binding !Saved}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Re-scan" Click="OnUpload" IsEnabled="{Binding CanUpload}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding StatusText}" IsVisible="{Binding HasStatus}" TextWrapping="Wrap"
                           HorizontalAlignment="Center" Foreground="{DynamicResource WarningBrush}"/>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
