# The app lives in web/ (Vue + Vite); its build artifacts are ignored by web/.gitignore.
# This root ignore only covers OS, editor, and stray dependency/output files.

# Dependencies and build output (in case tooling runs from the repo root)
node_modules/
dist/
dist-ssr/
*.tsbuildinfo

# Local env / secrets
.env
.env.local
*.local

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
.vscode/
*.swp
